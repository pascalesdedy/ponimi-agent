# ── LLM Provider ──────────────────────────────────────────────────────
# Pilih salah satu:
DEEPSEEK_API_KEY=sk-your-key-here
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Mode ──────────────────────────────────────────────────────────────
# Set ke "true" untuk pakai script mock (tanpa LLM, buat testing)
# LLM_MOCK=true

# Ponimi Agent — Environment Variables
# Copy this to /etc/ponimi.env on the server

# WAJIB: DeepSeek API Key
DEEPSEEK_API_KEY=sk-your-key-here

# Redis
REDIS_URL=redis://:change-me-redis-password@localhost:6379

# Webhook security (required for /run)
WEBHOOK_API_KEY=change-me-webhook-key
PONIMI_ALLOWED_ORIGINS=https://your-ui.example.com
WEBHOOK_MAX_BODY_BYTES=65536
WEBHOOK_RATE_LIMIT_PER_MINUTE=10

# Checkpoint retention
CHECKPOINT_TTL_DAYS=7

# Opsional: LLM Mock Mode (skip LLM calls, use mock scripts)
# LLM_MOCK=true
